# Copy this file to `.env.local` and edit the values to personalize the site links.
# Values prefixed with NEXT_PUBLIC_ will be available to the browser via Next.js.

NEXT_PUBLIC_GH=https://github.com/your-username
# NEXT_PUBLIC_IG=https://www.instagram.com/your-username
NEXT_PUBLIC_IN=https://www.linkedin.com/in/your-username
# WhatsApp: use the api link format or a short link. Example below opens chat with a preset message.
NEXT_PUBLIC_WA=https://api.whatsapp.com/send?phone=YOURPHONEWITHOUTPLUS&text=%3CHello%20from%20my%20site%20%2F%3E
